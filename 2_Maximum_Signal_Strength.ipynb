      "source": [
        "n = int(input())\n",
        "values = list(map(int, input().split()))\n",
        "k = int(input())\n",
        "\n",
        "current_sum = sum(values[:k])\n",
        "max_sum = current_sum\n",
        "\n",
        "for i in range(k, n):\n",
        "    current_sum = current_sum + values[i] - values[i - k]\n",
        "    if current_sum > max_sum:\n",
        "        max_sum = current_sum\n",
        "\n",
        "print(max_sum)"
      ]
    }
  ]
}