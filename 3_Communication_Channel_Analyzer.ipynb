      "source": [
        "s=input(\"enter string\")\n",
        "seen={}\n",
        "start=0\n",
        "long=0\n",
        "for i in range(len(s)):\n",
        "    ch=s[i]\n",
        "    if ch in seen and seen[ch]>=start:\n",
        "        start=seen[ch]+1\n",
        "    seen[ch]=i\n",
        "    if i-start+1>long:\n",
        "        long=i-start+1\n",
        "print(long)"
      ]
    }
  ]
